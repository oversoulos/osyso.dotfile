# =====================================================================
# --- PER-WORKSPACE AESTHETIC PIPELINE ---
# =====================================================================

# WORKSPACE 1: OVERSOUL (The Visual Command Center)
workspace = 1, gapsin:5, gapsout:10, border:true, decorate:true, default:true
windowrulev2 = opacity 1.0 0.9, workspace:1     # Soft transparency for background apps

# WORKSPACE 2: DEVOPS (The Minimal Sandbox)
# Stripped down, no extra decorations, larger spacing for clear focus
workspace = 2, gapsin:8, gapsout:16, border:true, decorate:false
windowrulev2 = opacity 1.0 1.0, workspace:2     # Full solid opacity for text reading

# WORKSPACE 3: EDITOR (The Inverted School & Media Vault)
# Zero gaps, zero borders, completely flat look
workspace = 3, gapsin:0, gapsout:0, border:false, decorate:false


# ====================================================================
# --- PHASE 4C: MASTER AESTHETICS (GAPS & ROUNDING) ---
# =====================================================================

general {
    gaps_in = 6                   # Gap between windows
    gaps_out = 12                 # Gap between windows and screen edges
    border_size = 2               # Outer window border width (pixels)
    
    # dark back ground with minima hazy neon pallet, irridecent  boarders, window frames, backlit , soft 
    col.active_border = rgba(33cceeee) rgba(ff79c6ee) 45deg
    col.inactive_border = rgba(595959aa)
}

decoration {
    rounding = 10                 # Smoothly rounds your window edges
    active_opacity = 1.0          # Opaque when working transparent lur when ot of focus
    inactive_opacity = 0.9        # Subtle dim on background apps
}  
 
animations {
    enabled = true
    bezier = snapCurve, 0.1, 0.9, 0.2, 1.0
    animation = windows, 1, 6, snapCurve
    animation = workspaces, 1, 5, default, slide
}

