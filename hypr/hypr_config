# =====================================================================
# --- GEOMETRY & WINDOW RULES ---
# =====================================================================

# 🟣 The AI Chatbox (Small black screen, neon purple border)
windowrulev2 = float, title:^(AI-Chatbox)$
windowrulev2 = size 400 600, title:^(AI-Chatbox)$
windowrulev2 = bordercolor rgba(8800ffeed) rgba(bf00ffeed) 45deg, title:^(AI-Chatbox)$

# 📐 Oversoul Quarter-Window Layouts (Casual Mode)
# Forces media to stay floating in a clean quadrant until you full-screen toggle it
windowrulev2 = float, class:^(spotify)$
windowrulev2 = size 25% 45%, class:^(spotify)$
windowrulev2 = move 2% 50%, class:^(spotify)$ # Anchors it to the bottom-left quarter

# Tabbed Stacking for Notes and Files
windowrulev2 = tile, class:^(obsidian)$
windowrulev2 = tile, class:^(nemo)$

# =====================================================================
# --- PHASE 4D: ACTIVITY KEYBINDS & QUICK-DRAW HOTKEYS ---
# =====================================================================

# Use the 'Super' key (Windows key) as your main shortcut modifier
$mainMod = SUPER

# Instant Terminal / File System Quick-Draw Hotkeys
bind = $mainMod, RETURN, exec, ghostty          # Hitting Enter draws a new command terminal
bind = $mainMod, E, exec, nemo                  # Hitting E draws your file tree manager
bind = $mainMod, SPACE, exec, rofi-wayland -show drun # Hitting Space draws your app drawer

# Basic Window Controls
bind = $mainMod, Q, killactive                  # Close focused program window
bind = $mainMod, F, fullscreen, 0               # Toggle full screen toggle
bind = $mainMod, V, togglefloating,             # Force a window to float over your canvas

# Workspace Switching Hotkeys
bind = $mainMod, 1, workspace, 1                # Move focus to oversoul(command center drop in dash board command center over casual/multiuse computing space)
bind = $mainMod, 2, workspace, 2                # Move focus to devops(sandboxed visual development workstation)
bind = $mainMod, 3, workspace, 3                # Move focus to editor(digital mixed media editing, light weight sandbox)

# Move active windows to different workspaces (For drag and drop operations)
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3


